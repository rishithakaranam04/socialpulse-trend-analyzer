# Reddit API Credentials
# Get these free at https://www.reddit.com/prefs/apps  (click "create another app", type = script)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=SocialTrendAnalyzer/1.0 by YourRedditUsername

# Flask config
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-any-random-long-string

# Optional defaults
DEFAULT_SUBREDDITS=technology,worldnews,business,science,programming
DEFAULT_POST_LIMIT=50
